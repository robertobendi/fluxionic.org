{% extends '@theme/layout.twig' %}
{% set meta_description = entry.field('meta_description', entry.field('topic')) %}

{% block title %}{{ entry.field('title') }} · {{ site.name }}{% endblock %}

{% block content %}
<article class="wrap">
    <p class="meta"><a href="/fellows">← All fellows</a></p>

    <header style="display:flex;align-items:flex-start;gap:1.25rem;flex-wrap:wrap;margin-bottom:1.5rem;">
        {% if entry.field('photo_url') %}
            <img src="{{ entry.field('photo_url') }}" alt="{{ entry.field('title') }}"
                 style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:1px solid var(--hairline);">
        {% endif %}
        <div>
            <h1 style="margin:0;">{{ entry.field('title') }}</h1>
            {% if entry.field('node_label') %}
                <p class="meta" style="margin:.25rem 0 0;">
                    {% if entry.field('node_slug') %}
                        <a href="/nodes/{{ entry.field('node_slug') }}">{{ entry.field('node_label') }}</a>
                    {% else %}{{ entry.field('node_label') }}{% endif %}
                </p>
            {% endif %}
            {% if entry.field('pi_name') %}
                <p class="meta" style="margin:.25rem 0 0;">Supervised by {{ entry.field('pi_name') }}</p>
            {% endif %}
        </div>
    </header>

    {% if entry.field('topic') %}
        <h2>Research topic</h2>
        <p>{{ entry.field('topic') }}</p>
    {% endif %}

    {% if entry.field('bio') %}
        <h2>About</h2>
        <div class="article-body">{{ entry.field('bio')|markdown }}</div>
    {% endif %}
</article>
{% endblock %}
