{% extends '@theme/layout.twig' %}

{% block title %}News · {{ site.name }}{% endblock %}

{# Split combined news+publications collection by kind. The list comes back
   already ordered by publish_at DESC from the controller. #}
{% set news_items = [] %}
{% set publications = [] %}
{% for e in entries %}
    {% if e.field('kind') == 'publication' %}
        {% set publications = publications|merge([e]) %}
    {% else %}
        {% set news_items = news_items|merge([e]) %}
    {% endif %}
{% endfor %}

{% block content %}
<div class="wrap-wide">
    <h1>News</h1>

    {% if news_items|length == 0 and publications|length == 0 %}
        <div class="empty-state"><p>No news yet — check back soon.</p></div>
    {% endif %}

    {% if news_items|length > 0 %}
        <section>
            {% for n in news_items %}
                <a class="news-card" href="/news/{{ n.slug }}">
                    <div class="date">{{ (n.publishAt ?? n.createdAt)|date('F j, Y') }}</div>
                    <h3>{{ n.field('title') }}</h3>
                    {% if n.field('summary') %}<p>{{ n.field('summary') }}</p>{% endif %}
                </a>
            {% endfor %}
        </section>
    {% endif %}

    {% if publications|length > 0 %}
        <section style="margin-top:3rem;">
            <h2>Publications</h2>
            <ol class="pub-list">
                {% for p in publications %}
                    {# Escape first, then wrap matched bold-names in <strong>; we
                       output |raw so the strong tags survive. #}
                    {% set authors_html = p.field('authors')|e %}
                    {% if p.field('bold_names') %}
                        {% for name in p.field('bold_names')|split(';') %}
                            {% set t = name|trim|e %}
                            {% if t %}
                                {% set authors_html = authors_html|replace({(t): '<strong>' ~ t ~ '</strong>'}) %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                    <li>
                        <em>{% if p.field('publication_url') %}<a href="{{ p.field('publication_url') }}" rel="noopener" target="_blank">{{ p.field('title') }}</a>{% else %}{{ p.field('title') }}{% endif %}</em>;
                        <em>{{ authors_html|raw }}</em>;
                        <em>{{ p.field('journal') }}{% if p.field('year') %} ({{ p.field('year') }}){% endif %}</em>
                    </li>
                {% endfor %}
            </ol>
        </section>
    {% endif %}
</div>
{% endblock %}
