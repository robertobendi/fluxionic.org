{% extends '@theme/layout.twig' %}

{% block title %}News · {{ site.name }}{% endblock %}

{% set news_items = [] %}
{% set publications = [] %}
{% for e in entries %}
    {% if e.field('kind') == 'publication' %}
        {% set publications = publications|merge([e]) %}
    {% else %}
        {% set news_items = news_items|merge([e]) %}
    {% endif %}
{% endfor %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <h1>News</h1>
        </div>
    </div>
</section>

{% if news_items|length > 0 %}
    <section class="section">
        <div class="container">
            <div class="card-grid">
                {% for n in news_items %}
                    <a class="news-card" href="/news/{{ n.slug }}">
                        {% if n.field('cover_url') %}
                            <img class="news-img" src="{{ n.field('cover_url') }}" alt="">
                        {% else %}
                            <div class="news-img" style="display:flex;align-items:center;justify-content:center;color:rgba(0,103,255,.4);font-family:'Poppins',sans-serif;">News</div>
                        {% endif %}
                        <div class="news-body">
                            <p class="news-date">{{ (n.publishAt ?? n.createdAt)|date('j M Y') }}</p>
                            <h3>{{ n.field('title') }}</h3>
                            {% if n.field('summary') %}<p>{{ n.field('summary') }}</p>{% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>
{% endif %}

{% if publications|length > 0 %}
    <section class="section" style="background:linear-gradient(to bottom, var(--light-blue-30), #fff);">
        <div class="container">
            <div class="article">
                <h2 style="text-align:center;margin-bottom:2rem;">Publications</h2>
                <ol class="pub-list">
                    {% for p in publications %}
                        {% set authors_html = p.field('authors')|e %}
                        {% if p.field('bold_names') %}
                            {% for name in p.field('bold_names')|split(';') %}
                                {% set t = name|trim|e %}
                                {% if t %}
                                    {% set authors_html = authors_html|replace({(t): '<strong>' ~ t ~ '</strong>'}) %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                        <li>
                            {% if p.field('publication_url') %}<a href="{{ p.field('publication_url') }}" rel="noopener" target="_blank">{{ p.field('title') }}</a>{% else %}{{ p.field('title') }}{% endif %};
                            {{ authors_html|raw }};
                            {{ p.field('journal') }}{% if p.field('year') %} ({{ p.field('year') }}){% endif %}
                        </li>
                    {% endfor %}
                </ol>
            </div>
        </div>
    </section>
{% endif %}

{% if news_items|length == 0 and publications|length == 0 %}
    <section class="section">
        <div class="container">
            <div class="empty-state"><p>No news yet — check back soon.</p></div>
        </div>
    </section>
{% endif %}
{% endblock %}
