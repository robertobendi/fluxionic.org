{% extends '@theme/layout.twig' %}
{% set meta_description = entry.field('meta_description', entry.field('summary')) %}

{% block title %}{{ entry.field('title') }} · {{ site.name }}{% endblock %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <a class="back-link" href="/outreach">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                All volunteering | outreach
            </a>
            <h1>{{ entry.field('title') }}</h1>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <article class="article">
            <div class="detail-meta">
                {% if entry.field('date_on') %}<span><span class="label">Date</span> {{ entry.field('date_on')|date('F j, Y') }}</span>{% endif %}
                {% if entry.field('location') %}<span><span class="label">Location</span> {{ entry.field('location') }}</span>{% endif %}
                {% if entry.field('fellow_name') %}<span><span class="label">Fellow</span> {{ entry.field('fellow_name') }}</span>{% endif %}
            </div>

            {% if entry.field('summary') %}<p style="font-size:1.125rem;color:var(--dark);font-weight:500;">{{ entry.field('summary') }}</p>{% endif %}
            {% if entry.field('role') %}
                <h2>Role</h2>
                <p>{{ entry.field('role')|nl2br }}</p>
            {% endif %}
            {% if entry.field('body') %}{{ entry.field('body')|markdown }}{% endif %}
            {% if entry.field('photos') %}
                <h2>Photos</h2>
                {{ entry.field('photos')|markdown }}
            {% endif %}
        </article>
    </div>
</section>
{% endblock %}
