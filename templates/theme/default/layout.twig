<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ site.name }}{% endblock %}</title>
    {% if meta_description is defined %}
        <meta name="description" content="{{ meta_description }}">
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #faf8f4;
            --surface: #ffffff;
            --ink: #1a1816;
            --ink-soft: #4a4541;
            --muted: #7a7370;
            --hairline: #e8e2d8;
            --accent: #b8431f;
            --accent-soft: #f5e8e1;
            --max: 720px;
        }
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            background: var(--bg);
            color: var(--ink);
            line-height: 1.65;
            font-size: 17px;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }
        h1, h2, h3, h4 {
            font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
            font-weight: 500;
            letter-spacing: -.015em;
            line-height: 1.15;
            color: var(--ink);
        }
        h1 { font-size: clamp(2rem, 5vw, 3.25rem); margin: 0 0 .5rem; }
        h2 { font-size: 1.875rem; margin: 2.5rem 0 .75rem; }
        h3 { font-size: 1.375rem; margin: 2rem 0 .5rem; }
        p, ul, ol, blockquote { margin: 0 0 1.25em; }
        a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
        a:hover { color: var(--ink); }
        img { max-width: 100%; height: auto; border-radius: 4px; }
        blockquote {
            border-left: 3px solid var(--accent);
            padding: .25rem 0 .25rem 1.25rem;
            color: var(--ink-soft);
            font-style: italic;
            margin-left: 0;
        }
        code {
            background: var(--accent-soft);
            color: var(--accent);
            padding: .125rem .375rem;
            border-radius: 3px;
            font-size: .9em;
            font-family: ui-monospace, "SF Mono", Menlo, monospace;
        }
        pre {
            background: var(--ink);
            color: #f5f0e8;
            padding: 1rem 1.25rem;
            border-radius: 6px;
            overflow-x: auto;
            font-size: .9em;
            line-height: 1.55;
        }
        pre code { background: transparent; color: inherit; padding: 0; }
        hr { border: 0; border-top: 1px solid var(--hairline); margin: 3rem 0; }

        .site-header {
            border-bottom: 1px solid var(--hairline);
            padding: 1.25rem clamp(1rem, 4vw, 2rem);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            flex-wrap: wrap;
            background: var(--surface);
        }
        .site-title {
            display: inline-flex;
            align-items: center;
            text-decoration: none;
        }
        .site-logo { height: 40px; width: auto; display: block; border-radius: 0; }
        .site-nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
        .site-nav a {
            color: var(--ink-soft);
            text-decoration: none;
            font-size: .9375rem;
            font-weight: 500;
        }
        .site-nav a:hover { color: var(--accent); }

        main { padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem); }
        .wrap { max-width: var(--max); margin: 0 auto; }
        .wrap-wide { max-width: 960px; margin: 0 auto; }

        .lede { font-size: 1.125rem; color: var(--ink-soft); }
        .meta { font-size: .875rem; color: var(--muted); margin-bottom: 2rem; }
        .meta a { color: var(--muted); }

        .post-card {
            display: block;
            padding: 1.5rem 0;
            border-bottom: 1px solid var(--hairline);
            text-decoration: none;
            color: inherit;
        }
        .post-card:last-child { border-bottom: 0; }
        .post-card h2 { margin: 0 0 .25rem; font-size: 1.5rem; }
        .post-card:hover h2 { color: var(--accent); }
        .post-card .date { font-size: .8125rem; color: var(--muted); }
        .post-card p { margin: .5rem 0 0; color: var(--ink-soft); }

        .site-footer {
            border-top: 1px solid var(--hairline);
            padding: 2rem clamp(1rem, 4vw, 2rem);
            text-align: center;
            color: var(--muted);
            font-size: .8125rem;
            margin-top: 4rem;
        }
        .site-footer a { color: var(--muted); }
        .footer-social { display: flex; justify-content: center; gap: 1rem; margin-bottom: .75rem; }
        .footer-social a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px; height: 36px;
            border-radius: 50%;
            color: var(--ink-soft);
            transition: color .15s ease, background .15s ease;
        }
        .footer-social a:hover { color: var(--accent); background: var(--accent-soft); }

        /* Card grids (nodes, fellows, conferences, outreach, news) */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.25rem;
            margin: 2rem 0 0;
        }
        .card {
            display: flex;
            flex-direction: column;
            border: 1px solid var(--hairline);
            border-radius: 8px;
            padding: 1.25rem;
            background: var(--surface);
            text-decoration: none;
            color: inherit;
            transition: border-color .15s ease, transform .15s ease;
        }
        .card:hover { border-color: var(--accent); transform: translateY(-2px); }
        .card h3 { margin: 0 0 .25rem; font-size: 1.25rem; }
        .card p { margin: .25rem 0 0; color: var(--ink-soft); font-size: .9375rem; }
        .card .card-meta { font-size: .8125rem; color: var(--muted); margin-top: .25rem; }
        .card .card-people { display: flex; gap: .5rem; margin-top: .75rem; flex-wrap: wrap; }
        .card .card-people img {
            width: 44px; height: 44px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid var(--hairline);
        }

        /* Detail-page person blocks */
        .person-row {
            display: grid;
            grid-template-columns: 96px 1fr;
            gap: 1.25rem;
            align-items: start;
            padding: 1.25rem 0;
            border-bottom: 1px solid var(--hairline);
        }
        .person-row:last-child { border-bottom: 0; }
        .person-row img {
            width: 96px; height: 96px;
            object-fit: cover;
            border-radius: 50%;
            border: 1px solid var(--hairline);
        }
        .person-row h3 { margin: 0 0 .25rem; font-size: 1.25rem; }
        .person-row .role { font-size: .8125rem; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; margin-bottom: .25rem; }
        .person-row .topic { color: var(--ink-soft); margin: .25rem 0 0; }

        /* News list — news cards + publications block */
        .news-card {
            display: block;
            padding: 1.25rem 0;
            border-bottom: 1px solid var(--hairline);
            text-decoration: none;
            color: inherit;
        }
        .news-card:last-child { border-bottom: 0; }
        .news-card h3 { margin: 0 0 .25rem; font-size: 1.375rem; }
        .news-card:hover h3 { color: var(--accent); }
        .pub-list { list-style: none; padding-left: 0; counter-reset: pub; }
        .pub-list li {
            counter-increment: pub;
            position: relative;
            padding-left: 2.25rem;
            margin-bottom: .85rem;
            font-style: italic;
            color: var(--ink-soft);
        }
        .pub-list li::before {
            content: counter(pub) ".";
            position: absolute;
            left: 0;
            width: 1.75rem;
            text-align: right;
            color: var(--muted);
            font-style: normal;
        }
        .pub-list li a { color: var(--accent); text-decoration: underline; }
        .pub-list li strong { color: var(--ink); font-style: italic; }

        /* Detail-page header media */
        .detail-meta {
            display: flex;
            gap: 1.25rem;
            flex-wrap: wrap;
            color: var(--muted);
            font-size: .9375rem;
            margin: 0 0 1.5rem;
        }
        .detail-meta span { display: inline-flex; align-items: center; }
        .detail-meta strong { color: var(--ink-soft); margin-right: .35rem; font-weight: 500; }

        .empty-state { text-align: center; padding: 4rem 0; color: var(--muted); }
        .empty-state h1 { color: var(--ink); }

        .article-body :first-child { margin-top: 0; }
        .article-body img { display: block; margin: 1.5rem auto; }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #1a1816; --surface: #221f1c; --ink: #f5f0e8; --ink-soft: #c9c1b6;
                --muted: #918a82; --hairline: #38332d; --accent: #d96a44; --accent-soft: #3a2620;
            }
            pre { background: #0d0c0a; color: #f5f0e8; }
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <header class="site-header">
        <a class="site-title" href="/">
            <img src="/assets/fluxionic-logo.png" alt="FLUXIONIC" class="site-logo">
        </a>
        <nav class="site-nav" aria-label="Primary">
            <a href="/">Home</a>
            <a href="/project">Project</a>
            <a href="/nodes">Nodes and Researchers</a>
            <a href="/fellows">Fellows</a>
            <a href="/events">Events</a>
            <a href="/conferences">Conferences | Workshops</a>
            <a href="/outreach">Volunteering | Outreach</a>
            <a href="/news">News</a>
        </nav>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <div class="footer-social">
            <a href="https://www.linkedin.com/company/fluxionic/" rel="noopener" target="_blank" aria-label="FLUXIONIC on LinkedIn">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18.34V10.5H5.67v7.84h2.67zM7 9.34a1.55 1.55 0 1 0 0-3.09 1.55 1.55 0 0 0 0 3.09zm11.34 9V13.9c0-2.4-1.28-3.52-3-3.52a2.59 2.59 0 0 0-2.35 1.3v-1.18h-2.66c.04.74 0 7.84 0 7.84h2.66v-4.38c0-.24.02-.48.09-.65.19-.48.62-.97 1.35-.97.95 0 1.33.72 1.33 1.78v4.22h2.58z"/></svg>
            </a>
            <a href="https://www.instagram.com/fluxionic_msca" rel="noopener" target="_blank" aria-label="FLUXIONIC on Instagram">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
        </div>
        <p>© {{ "now"|date('Y') }} FLUXIONIC. Funded by the European Union under the Marie Skłodowska-Curie Doctoral Network programme.</p>
    </footer>
</body>
</html>
