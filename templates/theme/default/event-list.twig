{% extends '@theme/layout.twig' %}

{% block title %}Events · {{ site.name }}{% endblock %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <h1>Events</h1>
            <p class="lede">Schools, workshops and conferences organised by the FLUXIONIC network.</p>
        </div>
    </div>
</section>

<section class="section" style="background:linear-gradient(to bottom, var(--light-blue-30), #fff);">
    <div class="container">
        {% if entries|length == 0 %}
            <div class="empty-state"><p>No events scheduled yet.</p></div>
        {% else %}
            <div class="card-grid">
                {% for ev in entries %}
                    <a class="news-card" href="/events/{{ ev.slug }}">
                        {% if ev.field('cover_url') %}
                            <img class="news-img" src="{{ ev.field('cover_url') }}" alt="">
                        {% else %}
                            <div class="news-img" style="display:flex;align-items:center;justify-content:center;color:rgba(0,103,255,.4);font-family:'Poppins',sans-serif;">Event</div>
                        {% endif %}
                        <div class="news-body">
                            {% if ev.field('starts_on') %}
                                <p class="news-date">
                                    {{ ev.field('starts_on')|date('j M Y') }}{% if ev.field('ends_on') and ev.field('ends_on') != ev.field('starts_on') %} – {{ ev.field('ends_on')|date('j M Y') }}{% endif %}
                                    {% if ev.field('location') %} · {{ ev.field('location') }}{% endif %}
                                </p>
                            {% endif %}
                            <h3>{{ ev.field('title') }}</h3>
                            {% if ev.field('summary') %}<p>{{ ev.field('summary') }}</p>{% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
