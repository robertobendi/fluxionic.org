{% extends '@theme/layout.twig' %}

{% block title %}Conferences | Workshops · {{ site.name }}{% endblock %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <h1>Conferences | Workshops</h1>
            <p class="lede">Conferences and workshops attended by FLUXIONIC fellows and PIs — talks, posters, awards.</p>
        </div>
    </div>
</section>

<section class="section" style="background:linear-gradient(to bottom, var(--light-blue-30), #fff);">
    <div class="container">
        {% if entries|length == 0 %}
            <div class="empty-state"><p>No entries yet.</p></div>
        {% else %}
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Topic</th>
                        <th>Dates</th>
                        <th>Location</th>
                    </tr>
                </thead>
                <tbody>
                    {% for c in entries %}
                        <tr>
                            <td><a href="/conferences/{{ c.slug }}">{{ c.field('title') }}</a></td>
                            <td class="secondary" style="white-space:nowrap;">
                                {% if c.field('starts_on') %}{{ c.field('starts_on')|date('M j, Y') }}{% endif %}
                                {% if c.field('ends_on') and c.field('ends_on') != c.field('starts_on') %} – {{ c.field('ends_on')|date('M j, Y') }}{% endif %}
                            </td>
                            <td class="secondary">{{ c.field('location') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</section>
{% endblock %}
