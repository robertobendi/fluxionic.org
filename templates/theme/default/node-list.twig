{% extends '@theme/layout.twig' %}

{% block title %}Nodes and Researchers · {{ site.name }}{% endblock %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <h1>Nodes and Researchers</h1>
            <p class="lede">{{ entries|length }} institutional nodes across Europe — Principal Investigators and the PhD researchers they supervise.</p>
        </div>
    </div>
</section>

<section class="section" style="background:linear-gradient(to bottom, var(--light-blue-30), #fff);">
    <div class="container">
        {% if entries|length == 0 %}
            <div class="empty-state"><p>No nodes published yet.</p></div>
        {% else %}
            <div class="card-grid">
                {% for node in entries %}
                    <a class="institution-card" href="/nodes/{{ node.slug }}">
                        <div class="card-head">
                            <div>
                                <h3>{{ node.field('title') }}</h3>
                                <span class="location">
                                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    {{ node.field('location') }}{% if node.field('country') %}, {{ node.field('country') }}{% endif %}
                                </span>
                            </div>
                            {% if node.field('abbrev') %}
                                <span class="pill">{{ node.field('abbrev') }}</span>
                            {% endif %}
                        </div>

                        {% if node.field('associates') %}
                            <p class="associates"><strong>Associated:</strong> {{ node.field('associates') }}</p>
                        {% endif %}

                        <div class="pi-list-divider">
                            <h4>Principal Investigators</h4>
                            {% for i in 1..4 %}
                                {% if node.field('pi_' ~ i ~ '_name') %}
                                    <div class="pi-row">
                                        {% if node.field('pi_' ~ i ~ '_photo_url') %}
                                            <img class="avatar avatar-sm" src="{{ node.field('pi_' ~ i ~ '_photo_url') }}" alt="{{ node.field('pi_' ~ i ~ '_name') }}">
                                        {% else %}
                                            <span class="avatar avatar-sm placeholder">{{ node.field('pi_' ~ i ~ '_name')|slice(0, 1) }}</span>
                                        {% endif %}
                                        <span style="font-size:.875rem;color:var(--dark);">{{ node.field('pi_' ~ i ~ '_name') }}</span>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>

                        {% set has_students = false %}
                        {% for i in 1..4 %}{% if node.field('student_' ~ i ~ '_name') %}{% set has_students = true %}{% endif %}{% endfor %}
                        {% if has_students %}
                            <div class="pi-list-divider" style="margin-top:.75rem;">
                                <h4>PhD Researchers</h4>
                                {% for i in 1..4 %}
                                    {% if node.field('student_' ~ i ~ '_name') %}
                                        <div class="pi-row">
                                            {% if node.field('student_' ~ i ~ '_photo_url') %}
                                                <img class="avatar avatar-sm" src="{{ node.field('student_' ~ i ~ '_photo_url') }}" alt="{{ node.field('student_' ~ i ~ '_name') }}">
                                            {% else %}
                                                <span class="avatar avatar-sm placeholder">{{ node.field('student_' ~ i ~ '_name')|slice(0, 1) }}</span>
                                            {% endif %}
                                            <span style="font-size:.875rem;color:var(--dark);">{{ node.field('student_' ~ i ~ '_name') }}</span>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
