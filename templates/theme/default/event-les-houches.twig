<script>
(function () {
    var navLinks = document.querySelectorAll('.lh-nav a, .lh-mnav a');
    var sections = Array.from(document.querySelectorAll('section[id]'));
    var scrollTop = document.getElementById('lh-scroll-top');
    var toggle = document.getElementById('lh-toggle');

    function setActive() {
        var pos = window.scrollY + 100;
        var current = sections[0] && sections[0].id;
        for (var i = 0; i < sections.length; i++) {
            if (sections[i].offsetTop <= pos) current = sections[i].id;
        }
        navLinks.forEach(function (link) {
            var href = link.getAttribute('href');
            if (href === '#' + current) link.classList.add('is-active');
            else link.classList.remove('is-active');
        });
        if (scrollTop) {
            if (window.scrollY > 300) scrollTop.classList.add('is-shown');
            else scrollTop.classList.remove('is-shown');
        }
    }
    window.addEventListener('scroll', setActive, { passive: true });
    setActive();

    if (scrollTop) scrollTop.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    document.querySelectorAll('.lh-mnav a').forEach(function (a) {
        a.addEventListener('click', function () { if (toggle) toggle.checked = false; });
    });
})();
</script>

