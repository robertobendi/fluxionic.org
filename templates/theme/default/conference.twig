{% extends '@theme/layout.twig' %}
{% set meta_description = entry.field('meta_description') %}

{% block title %}{{ entry.field('title') }} · {{ site.name }}{% endblock %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <a class="back-link" href="/conferences">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                All conferences | workshops
            </a>
            <h1>{{ entry.field('title') }}</h1>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <article class="article">
            <div class="detail-meta">
                {% if entry.field('starts_on') %}
                    <span><span class="label">Dates</span> {{ entry.field('starts_on')|date('F j, Y') }}{% if entry.field('ends_on') and entry.field('ends_on') != entry.field('starts_on') %} – {{ entry.field('ends_on')|date('F j, Y') }}{% endif %}</span>
                {% endif %}
                {% if entry.field('location') %}<span><span class="label">Location</span> {{ entry.field('location') }}</span>{% endif %}
            </div>

            {% if entry.field('talk_given') %}
                <h2>Talk given</h2>
                <p>{{ entry.field('talk_given')|nl2br }}</p>
            {% endif %}
            {% if entry.field('poster') %}
                <h2>Poster presented</h2>
                <p>{{ entry.field('poster')|nl2br }}</p>
            {% endif %}
            {% if entry.field('attendees') %}
                <h2>Fellows and PIs who attended</h2>
                <p>{{ entry.field('attendees')|nl2br }}</p>
            {% endif %}
            {% if entry.field('awards') %}
                <h2>Awards won</h2>
                <p>{{ entry.field('awards')|nl2br }}</p>
            {% endif %}
            {% if entry.field('photos') %}
                <h2>Photos</h2>
                {{ entry.field('photos')|markdown }}
            {% endif %}
            {% if entry.field('notes') %}
                <h2>Notes</h2>
                {{ entry.field('notes')|markdown }}
            {% endif %}
        </article>
    </div>
</section>
{% endblock %}
