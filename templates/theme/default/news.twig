{% extends '@theme/layout.twig' %}
{% set meta_description = entry.field('meta_description', entry.field('summary')) %}

{% block title %}{{ entry.field('title') }} · {{ site.name }}{% endblock %}

{% block content %}
<article class="wrap">
    <p class="meta"><a href="/news">← All news</a></p>

    {% if entry.field('kind') == 'publication' %}
        <h1>{{ entry.field('title') }}</h1>
        <p class="meta">
            {% if entry.field('journal') %}{{ entry.field('journal') }}{% endif %}
            {% if entry.field('year') %} ({{ entry.field('year') }}){% endif %}
        </p>
        {% if entry.field('authors') %}
            {% set authors_html = entry.field('authors')|e %}
            {% if entry.field('bold_names') %}
                {% for name in entry.field('bold_names')|split(';') %}
                    {% set t = name|trim|e %}
                    {% if t %}
                        {% set authors_html = authors_html|replace({(t): '<strong>' ~ t ~ '</strong>'}) %}
                    {% endif %}
                {% endfor %}
            {% endif %}
            <p><em>{{ authors_html|raw }}</em></p>
        {% endif %}
        {% if entry.field('publication_url') %}
            <p><a href="{{ entry.field('publication_url') }}" rel="noopener" target="_blank">Read the publication →</a></p>
        {% endif %}
    {% else %}
        <h1>{{ entry.field('title') }}</h1>
        <p class="meta">{{ (entry.publishAt ?? entry.createdAt)|date('F j, Y') }}</p>
        {% if entry.field('cover_url') %}
            <img src="{{ entry.field('cover_url') }}" alt="" style="width:100%;border-radius:8px;margin-bottom:1.5rem;">
        {% endif %}
        {% if entry.field('summary') %}<p class="lede">{{ entry.field('summary') }}</p>{% endif %}
        {% if entry.field('body') %}
            <div class="article-body">{{ entry.field('body')|markdown }}</div>
        {% endif %}
    {% endif %}
</article>
{% endblock %}
