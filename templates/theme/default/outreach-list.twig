{% extends '@theme/layout.twig' %}

{% block title %}Volunteering | Outreach · {{ site.name }}{% endblock %}

{% block content %}
<section class="hero hero-soft">
    <div class="container">
        <div class="hero-narrow">
            <h1>Volunteering | Outreach</h1>
            <p class="lede">Outreach and volunteering activities by FLUXIONIC fellows and PIs.</p>
        </div>
    </div>
</section>

<section class="section" style="background:linear-gradient(to bottom, var(--light-blue-30), #fff);">
    <div class="container">
        {% if entries|length == 0 %}
            <div class="empty-state"><p>No activities yet.</p></div>
        {% else %}
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Activity</th>
                        <th>Date</th>
                        <th>Location</th>
                        <th>Fellow</th>
                    </tr>
                </thead>
                <tbody>
                    {% for o in entries %}
                        <tr>
                            <td>
                                <a href="/outreach/{{ o.slug }}">{{ o.field('title') }}</a>
                                {% if o.field('summary') %}<div class="secondary" style="margin-top:.25rem;">{{ o.field('summary') }}</div>{% endif %}
                            </td>
                            <td class="secondary" style="white-space:nowrap;">{% if o.field('date_on') %}{{ o.field('date_on')|date('M j, Y') }}{% endif %}</td>
                            <td class="secondary">{{ o.field('location') }}</td>
                            <td class="secondary">{{ o.field('fellow_name') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</section>
{% endblock %}
